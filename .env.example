# AI (optional — service runs without it via rule-based fallback)
# Free key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=12

# Email (Mailtrap sandbox recommended for the demo)
OWNER_EMAIL=owner@example.com
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@devlanding.local

# Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=600

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Storage
DATA_DIR=data